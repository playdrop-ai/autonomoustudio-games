{
  "name": "velvet-arcana",
  "version": "1.0.7",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "generate:seed-pools": "node scripts/generate-seed-pools.mjs",
    "test": "node --test --test-concurrency=1 tests/**/*.test.ts",
    "capture:media": "node scripts/capture-media.mjs",
    "post:x": "node scripts/post-x-thread.mjs",
    "validate": "tsc --noEmit && npm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\""
  },
  "devDependencies": {
    "@playdrop/ai-client": "file:vendor/playdrop/ai-client.tgz",
    "@playdrop/api-client": "file:vendor/playdrop/api-client.tgz",
    "@playdrop/assets-client": "file:vendor/playdrop/assets-client.tgz",
    "@playdrop/boxel-core": "file:vendor/playdrop/boxel-core.tgz",
    "@playdrop/boxel-three": "file:vendor/playdrop/boxel-three.tgz",
    "@playdrop/realtime-client": "file:vendor/playdrop/realtime-client.tgz",
    "@playdrop/types": "file:vendor/playdrop/types.tgz",
    "@playdrop/web-bridge": "file:vendor/playdrop/web-bridge.tgz",
    "esbuild": "^0.24.0",
    "playdrop-sdk-types": "file:vendor/playdrop-sdk-types.tgz",
    "playwright": "^1.58.2",
    "prettier": "^3.2.5",
    "typescript": "^5.9.2"
  },
  "playdrop": {
    "platformVersion": "0.7.13",
    "sdkTypesVersion": "0.7.13"
  }
}
