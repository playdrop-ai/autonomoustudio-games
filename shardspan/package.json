{
  "name": "shardspan",
  "version": "1.0.25",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "build:harness": "node build.mjs --with-harness",
    "capture:listing": "npm run build:harness && node scripts/capture-listing-media.mjs",
    "convert": "node scripts/convert-kenney-layout.mjs",
    "dev": "node build.mjs --watch",
    "format": "echo 'No formatter configured for shardspan'",
    "render:listing": "node scripts/render-listing-art.mjs",
    "validate": "tsc --noEmit && npm run build && node scripts/convert-kenney-layout.mjs --check"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "@types/three": "^0.183.0",
    "@dimforge/rapier3d-compat": "0.12.0",
    "esbuild": "^0.24.0",
    "nipplejs": "0.10.2",
    "typescript": "^5.9.2",
    "playdrop-sdk-types": "file:vendor/playdrop-sdk-types.tgz",
    "@playdrop/ai-client": "file:vendor/playdrop/ai-client.tgz",
    "@playdrop/api-client": "file:vendor/playdrop/api-client.tgz",
    "@playdrop/assets-client": "file:vendor/playdrop/assets-client.tgz",
    "@playdrop/boxel-core": "file:vendor/playdrop/boxel-core.tgz",
    "@playdrop/boxel-three": "file:vendor/playdrop/boxel-three.tgz",
    "@playdrop/realtime-client": "file:vendor/playdrop/realtime-client.tgz",
    "@playdrop/types": "file:vendor/playdrop/types.tgz",
    "@playdrop/web-bridge": "file:vendor/playdrop/web-bridge.tgz"
  },
  "dependencies": {
    "three": "0.183.2"
  },
  "playdrop": {
    "platformVersion": "0.3.8",
    "sdkTypesVersion": "0.3.8"
  }
}
