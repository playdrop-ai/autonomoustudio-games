{
  "name": "keyfall",
  "version": "0.4.0",
  "type": "module",
  "private": true,
  "scripts": {
    "build": "node build.mjs",
    "dev": "node build.mjs --watch",
    "test": "node --experimental-strip-types --test tests/**/*.test.ts",
    "charts:build": "python3 scripts/build_audio_charts.py",
    "charts:validate": "python3 scripts/build_audio_charts.py --check",
    "charts:render": "python3 scripts/render_chart_analysis.py",
    "balance:report": "node --experimental-strip-types scripts/simulate-balance.ts",
    "chart:report": "node --experimental-strip-types scripts/chart-report.ts",
    "playtest:content": "node scripts/playtest-content.mjs",
    "capture:marketing": "node scripts/capture-marketing-video.mjs",
    "capture:songs": "node scripts/capture-song-videos.mjs",
    "validate": "npm run charts:validate && npm run test && tsc --noEmit && npm run build",
    "format": "prettier --write \"src/**/*.{ts,tsx,js,jsx,json}\""
  },
  "devDependencies": {
    "@playdrop/ai-client": "file:vendor/playdrop/ai-client.tgz",
    "@playdrop/api-client": "file:vendor/playdrop/api-client.tgz",
    "@playdrop/assets-client": "file:vendor/playdrop/assets-client.tgz",
    "@playdrop/boxel-core": "file:vendor/playdrop/boxel-core.tgz",
    "@playdrop/boxel-three": "file:vendor/playdrop/boxel-three.tgz",
    "@playdrop/realtime-client": "file:vendor/playdrop/realtime-client.tgz",
    "@playdrop/types": "file:vendor/playdrop/types.tgz",
    "@playdrop/web-bridge": "file:vendor/playdrop/web-bridge.tgz",
    "esbuild": "^0.24.0",
    "playdrop-sdk-types": "file:vendor/playdrop-sdk-types.tgz",
    "playwright": "^1.58.1",
    "prettier": "^3.2.5",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "three": "^0.183.2"
  },
  "playdrop": {
    "platformVersion": "0.4.0",
    "sdkTypesVersion": "0.4.0"
  }
}
